generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                 String              @id @default(cuid())
  name               String              @unique
  avatarUrl          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  customers          Customer[]
  customerLocations  CustomerLocation[]
  documents          Document[]
  drivers            Driver[]
  fuelLogs           FuelLog[]
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  issues             Issue[]
  maintenanceRecords MaintenanceRecord[]
  roles              Role[]
  routes             Route[]
  routeStops         RouteStop[]
  shipments          Shipment[]
  shipmentHistory    ShipmentHistory[]
  shipmentItems      ShipmentItem[]
  shipmentStops      ShipmentStop[]
  trailers           Trailer[]
  trailerAssignments TrailerAssignment[]
  users              User[]
  vehicles           Vehicle[]
  warehouses         Warehouse[]
  warehouseZones     WarehouseZone[]
  warehouseTasks     WarehouseTask[]

  @@map("companies")
}

// companyId == null  -> immutable system role (seeded, shared read-only catalog)
// companyId != null  -> tenant-owned custom role, editable only by that tenant
model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  permissions String[]
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  users       User[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  name                   String
  surname                String
  password               String?
  avatarUrl              String?
  roleId                 String?
  status                 UserStatus          @default(ACTIVE)
  lastLoginAt            DateTime?
  companyId              String?
  timezone               String              @default("UTC")
  dateFormat             String              @default("DD/MM/YYYY")
  timeFormat             String              @default("24h")
  currency               String
  notifEmailShipment     Boolean             @default(true)
  notifEmailMaint        Boolean             @default(true)
  notifEmailWeekly       Boolean             @default(false)
  notifPushAssignment    Boolean             @default(true)
  notifPushDelay         Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  language               String              @default("en")
  auditLogs              AuditLog[]
  driver                 Driver?
  inventoryMovements     InventoryMovement[]
  sessions               Session[]
  subscription           Subscription?
  shipmentHistoryEntries ShipmentHistory[]   @relation("ShipmentHistoryCreatedBy")
  company                Company?            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role                   Role?               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  managedWarehouses      Warehouse[]
  assignedWarehouseTasks WarehouseTask[]

  @@index([companyId])
  @@index([roleId])
  @@map("users")
}

model Driver {
  id                  String       @id @default(cuid())
  userId              String       @unique
  employeeId          String
  licenseNumber       String?
  licenseType         String?
  licenseExpiry       DateTime?
  phone               String
  status              DriverStatus @default(OFF_DUTY)
  safetyScore         Int?
  efficiencyScore     Int?
  rating              Float?
  hazmatCertified     Boolean      @default(false)
  languages           String[]
  currentVehicleId    String?      @unique
  companyId           String
  homeBaseWarehouseId String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  documents           Document[]
  company             Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currentVehicle      Vehicle?     @relation(fields: [currentVehicleId], references: [id], onDelete: Restrict)
  homeBaseWarehouse   Warehouse?   @relation(fields: [homeBaseWarehouseId], references: [id], onDelete: Restrict)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelLogs            FuelLog[]
  issues              Issue[]
  routes              Route[]
  shipments           Shipment[]

  @@unique([companyId, employeeId])
  @@index([companyId, status])
  @@index([homeBaseWarehouseId])
  // Serves the check-expirations cron's cross-tenant license sweep
  // (`licenseExpiry <= cutoff` with no companyId filter).
  @@index([licenseExpiry])
  @@map("drivers")
}

model Vehicle {
  id                 String              @id @default(cuid())
  fleetNo            String
  plate              String
  type               VehicleType
  brand              String
  model              String
  year               Int
  status             VehicleStatus       @default(AVAILABLE)
  maxLoadKg          Int
  fuelType           FuelType
  currentLat         Float?
  currentLng         Float?
  fuelLevel          Int?
  odometerKm         Int?
  companyId          String
  nextServiceKm      Int?
  avgFuelConsumption Float?
  registrationExpiry DateTime?
  inspectionExpiry   DateTime?
  engineSize         String?
  transmission       String?
  techNotes          String?
  photo              String?
  enableAlerts       Boolean?            @default(true)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  fuelCapacity       Int?
  documents          Document[]
  driver             Driver?
  fuelLogs           FuelLog[]
  issues             Issue[]
  maintenanceRecords MaintenanceRecord[]
  routes             Route[]
  trailerAssignments TrailerAssignment[]
  currentTrailer     Trailer?
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, fleetNo])
  @@unique([companyId, plate])
  @@index([companyId, status])
  // Serve the check-expirations cron's cross-tenant registration/inspection
  // sweep (`registrationExpiry <= cutoff OR inspectionExpiry <= cutoff`).
  @@index([registrationExpiry])
  @@index([inspectionExpiry])
  @@map("vehicles")
}

model MaintenanceRecord {
  id               String            @id @default(cuid())
  vehicleId        String
  companyId        String
  type             MaintenanceType
  date             DateTime
  cost             Decimal           @db.Decimal(12, 2)
  originalCost     Decimal?          @db.Decimal(12, 2)
  originalCurrency String?
  status           MaintenanceStatus @default(COMPLETED)
  description      String?
  currency         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  documentUrl      String?
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([vehicleId, date])
  @@index([companyId, date])
  @@map("maintenance_records")
}

model Warehouse {
  id               String              @id @default(cuid())
  code             String
  name             String
  type             WarehouseType
  address          String
  city             String
  country          String
  lat              Float?
  lng              Float?
  capacityPallets  Int                 @default(5000)
  capacityVolumeM3 Int                 @default(100000)
  operatingHours   String?             @default("08:00 - 18:00")
  timezone         String              @default("UTC")
  specifications   String[]            @default([])
  managerId        String?
  companyId        String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  drivers          Driver[]
  inventory        Inventory[]
  movements        InventoryMovement[]
  shipmentsOrigin  Shipment[]          @relation("ShipmentOrigin")
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  manager          User?               @relation(fields: [managerId], references: [id], onDelete: Restrict)
  zones            WarehouseZone[]
  tasks            WarehouseTask[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([managerId])
  @@map("warehouses")
}

model WarehouseZone {
  id              String    @id @default(cuid())
  warehouseId     String
  companyId       String
  code            String
  name            String?
  capacityPallets Int       @default(0)
  usedPallets     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code])
  @@index([companyId])
  @@map("warehouse_zones")
}

model WarehouseTask {
  id           String                @id @default(cuid())
  warehouseId  String
  companyId    String
  kind         WarehouseTaskKind
  name         String
  orderRef     String
  zone         String
  doneUnits    Int                   @default(0)
  totalUnits   Int
  priority     WarehouseTaskPriority @default(MEDIUM)
  status       WarehouseTaskStatus   @default(OPEN)
  assignedToId String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  assignedTo   User?                 @relation(fields: [assignedToId], references: [id], onDelete: Restrict)
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([warehouseId, status])
  @@index([companyId, status])
  @@index([assignedToId, status])
  @@map("warehouse_tasks")
}

model Customer {
  id        String             @id @default(cuid())
  code      String
  name      String
  industry  String?
  taxId     String?
  email     String?
  phone     String?
  companyId String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  locations CustomerLocation[]
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  stops     ShipmentStop[]
  shipments Shipment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("customers")
}

model CustomerLocation {
  id         String         @id @default(cuid())
  customerId String
  companyId  String
  name       String
  address    String
  lat        Float?
  lng        Float?
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stops      ShipmentStop[]
  shipments  Shipment[]

  @@index([customerId])
  @@index([companyId])
  @@map("customer_locations")
}

model Inventory {
  id                String    @id @default(cuid())
  warehouseId       String
  sku               String
  name              String
  zone              String?
  quantity          Int
  allocatedQuantity Int       @default(0)
  minStock          Int       @default(0)
  imageUrl          String?
  unitValue         Decimal?  @default(0) @db.Decimal(12, 2)
  currency          String
  unit              String
  weightKg          Float?    @default(0)
  volumeM3          Float?    @default(0)
  palletCount       Int?      @default(0)
  cargoType         String?
  updatedAt         DateTime  @updatedAt
  companyId         String
  createdAt         DateTime  @default(now())
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([warehouseId, sku])
  @@index([companyId])
  @@map("inventory")
}

model InventoryMovement {
  id          String       @id @default(cuid())
  warehouseId String
  sku         String
  quantity    Int
  type        MovementType
  notes       String?
  date        DateTime     @default(now())
  userId      String?
  companyId   String
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user        User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([warehouseId, sku, date])
  @@index([companyId, date])
  @@index([userId])
  @@map("inventory_movements")
}

model Shipment {
  id                 String               @id @default(cuid())
  // trackingId is intentionally globally unique: it is an opaque public
  // tracking token that must be resolvable without a tenant context.
  trackingId         String               @unique
  referenceNumber    String?
  customerId         String?
  customerLocationId String?
  driverId           String?
  status             ShipmentStatus       @default(PENDING)
  origin             String?
  originLat          Float?
  originLng          Float?
  destination        String
  destinationLat     Float?
  destinationLng     Float?
  itemsCount         Int                  @default(1)
  priority           ShipmentPriority     @default(MEDIUM)
  type               ShipmentServiceType  @default(STANDARD_FREIGHT)
  slaDeadline        DateTime?
  weightKg           Float?               @default(0)
  volumeM3           Float?               @default(0)
  palletCount        Int?                 @default(0)
  cargoType          String?
  contactEmail       String?
  billingAccount     String?
  routeId            String?
  companyId          String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  originWarehouseId  String?
  trailerId          String?
  issues             Issue[]
  history            ShipmentHistory[]
  items              ShipmentItem[]
  stops              ShipmentStop[]
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer           Customer?            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerLocation   CustomerLocation?    @relation(fields: [customerLocationId], references: [id], onDelete: Restrict)
  driver             Driver?              @relation(fields: [driverId], references: [id], onDelete: Restrict)
  originWarehouse    Warehouse?           @relation("ShipmentOrigin", fields: [originWarehouseId], references: [id], onDelete: Restrict)
  route              Route?               @relation(fields: [routeId], references: [id], onDelete: Restrict)
  trailer            Trailer?             @relation(fields: [trailerId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, trackingId])
  // Serves the check-expirations cron's cross-tenant SLA sweep
  // (`status IN (...) AND slaDeadline < now`), which has no companyId filter
  // by design — it processes every tenant in one pass.
  @@index([status, slaDeadline])
  @@index([driverId, status])
  @@index([customerId])
  @@index([customerLocationId])
  @@index([routeId])
  @@index([originWarehouseId])
  @@index([trailerId])
  @@map("shipments")
}

model ShipmentHistory {
  id            String         @id @default(cuid())
  shipmentId    String
  companyId     String
  status        ShipmentStatus
  location      String?
  description   String?
  createdAt     DateTime       @default(now())
  createdById   String?
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdByUser User?          @relation("ShipmentHistoryCreatedBy", fields: [createdById], references: [id])
  shipment      Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([createdById])
  @@index([companyId])
  @@map("shipment_history")
}

model ShipmentStop {
  id                 String            @id @default(cuid())
  shipmentId         String
  companyId          String
  customerId         String?
  customerLocationId String?
  address            String
  lat                Float?
  lng                Float?
  sequence           Int
  status             ShipmentStatus    @default(PENDING)
  arrivalDate        DateTime?
  departureDate      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  contactEmail       String?
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerLocation   CustomerLocation? @relation(fields: [customerLocationId], references: [id], onDelete: Restrict)
  shipment           Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sequence])
  @@index([customerId])
  @@index([customerLocationId])
  @@index([companyId])
  @@map("shipment_stops")
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  companyId   String
  sku         String
  name        String
  quantity    Int
  unit        String
  weightKg    Float?   @default(0)
  volumeM3    Float?   @default(0)
  palletCount Int?     @default(0)
  cargoType   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([companyId])
  @@map("shipment_items")
}

model Route {
  id          String      @id @default(cuid())
  name        String?
  status      RouteStatus @default(PLANNED)
  date        DateTime
  startTime   DateTime?
  endTime     DateTime?
  distanceKm  Float?
  durationMin Int?
  driverId    String?
  vehicleId   String?
  companyId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  driver      Driver?     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  shipments   Shipment[]
  stops       RouteStop[]

  @@index([companyId, date])
  @@index([driverId, date])
  @@index([vehicleId])
  // Serves the check-expirations cron's cross-tenant delayed/upcoming sweep
  // (`status IN ('PLANNED','ACTIVE')` with no companyId filter).
  @@index([status])
  @@map("routes")
}

model RouteStop {
  id        String   @id @default(cuid())
  routeId   String
  companyId String
  sequence  Int
  address   String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId, sequence])
  @@index([companyId])
  @@map("route_stops")
}

model Document {
  id         String         @id @default(cuid())
  type       DocumentType
  name       String
  url        String
  expiryDate DateTime?
  status     DocumentStatus
  driverId   String?
  vehicleId  String?
  companyId  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  trailerId  String?
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  driver     Driver?        @relation(fields: [driverId], references: [id], onDelete: Restrict)
  trailer    Trailer?       @relation(fields: [trailerId], references: [id], onDelete: Restrict)
  vehicle    Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([companyId, expiryDate])
  // Serves the check-expirations cron's cross-tenant sweep (expiryDate
  // filtered with no companyId), which can't use the composite index above.
  @@index([expiryDate])
  @@index([driverId])
  @@index([vehicleId])
  @@index([trailerId])
  @@map("documents")
}

model FuelLog {
  id          String   @id @default(cuid())
  vehicleId   String
  driverId    String
  companyId   String
  date        DateTime @default(now())
  volumeLiter Float
  cost        Decimal  @db.Decimal(12, 2)
  odometerKm  Int
  location    String?
  fuelType    FuelType
  currency    String
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([companyId, date])
  @@index([vehicleId, date])
  @@index([driverId, date])
  @@map("fuel_logs")
}

model Issue {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      IssueStatus   @default(OPEN)
  priority    IssuePriority @default(MEDIUM)
  type        IssueType     @default(OTHER)
  vehicleId   String?
  driverId    String?
  shipmentId  String?
  companyId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  trailerId   String?
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  driver      Driver?       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  shipment    Shipment?     @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  trailer     Trailer?      @relation(fields: [trailerId], references: [id], onDelete: Restrict)
  vehicle     Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([shipmentId])
  @@index([trailerId])
  @@map("issues")
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  refreshToken   String   @unique
  deviceInfo     String?
  ipAddress      String?
  lastActivityAt DateTime @default(now())
  expiresAt      DateTime
  isRevoked      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime    @default(now())
  metadata   Json?
  user       User?       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  rates     Json
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([base, date])
  @@map("exchange_rates")
}

model Trailer {
  id               String              @id @default(cuid())
  fleetNo          String
  plate            String
  type             TrailerType
  capacityVolumeM3 Float
  maxLoadKg        Int
  isColdChain      Boolean             @default(false)
  status           TrailerStatus       @default(AVAILABLE)
  currentVehicleId String?             @unique
  companyId        String
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  documents        Document[]
  issues           Issue[]
  shipments        Shipment[]
  assignments      TrailerAssignment[]
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currentVehicle   Vehicle?            @relation(fields: [currentVehicleId], references: [id], onDelete: Restrict)

  @@unique([companyId, fleetNo])
  @@unique([companyId, plate])
  @@index([companyId, status])
  @@map("trailers")
}

model TrailerAssignment {
  id         String    @id @default(cuid())
  trailerId  String
  vehicleId  String
  companyId  String
  assignedAt DateTime  @default(now())
  detachedAt DateTime?
  notes      String?
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  trailer    Trailer   @relation(fields: [trailerId], references: [id], onDelete: Restrict)
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([trailerId, assignedAt])
  @@index([vehicleId, assignedAt])
  @@index([companyId])
  @@map("trailer_assignments")
}

// Public, tenant-agnostic lead capture from the landing "Request a Demo" form.
// Intentionally has NO companyId: submissions arrive from anonymous visitors
// before any tenant/company exists, so this model sits OUTSIDE the tenant-guard
// Prisma extension and must never be queried through a company-scoped context.
model DemoRequest {
  id        String            @id @default(cuid())
  fullName  String
  email     String
  company   String?
  message   String?
  // Distinguishes a demo request (from a "Request a Demo" CTA) from a plain
  // contact-form message, so the two don't get mixed up in the same table.
  type      DemoRequestType   @default(CONTACT)
  status    DemoRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Serves the "does this email have an approved demo?" CTA-gating lookup.
  @@index([email, status])
  @@index([type, status])
  @@map("demo_requests")
}

enum DemoRequestType {
  DEMO
  CONTACT
}

enum DemoRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Per-user access entitlement. Gates company creation and dashboard access.
// NOT a tenant model (no companyId): it exists before a company does and is
// keyed on the user. Managed manually for now (no payment integration) — an
// approved demo request opens a 7-day TRIAL; ACTIVE is set by hand.
model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  status           SubscriptionStatus @default(NONE)
  plan             String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  EXPIRED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

