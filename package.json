{
  "name": "logitrackv2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "shx rm -rf node_modules/.prisma && prisma generate && next build && shx mkdir -p .next/standalone/public && shx cp -r public/* .next/standalone/public/ && shx mkdir -p .next/standalone/.next/static && shx cp -r .next/static/* .next/standalone/.next/static/",
    "start": "dotenv -e .env -- node .next/standalone/server.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:run": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test:users": "tsx scripts/test-users.ts",
    "firebase:seed-location": "tsx scripts/seed-firebase-locations.ts",
    "firebase:simulate-trip": "tsx scripts/simulate-trip.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/x-charts": "^8.26.0",
    "@mui/x-date-pickers": "^8.26.0",
    "@prisma/client": "^5.10.2",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/speed-insights": "^2.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.19",
    "firebase": "^12.11.0",
    "formik": "^2.4.9",
    "framer-motion": "^12.36.0",
    "install": "^0.13.0",
    "jose": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.3",
    "npm": "^11.10.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "sonner": "^2.0.7",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001777",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^5.10.2",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
