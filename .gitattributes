# Normalize line endings: store as LF in the repository and check out as LF on
# every platform. Stops the "LF will be replaced by CRLF" churn/warnings that
# core.autocrlf produces on Windows and keeps diffs clean across the team.
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary

# Lockfiles: keep LF, avoid accidental CRLF diffs.
package-lock.json text eol=lf
